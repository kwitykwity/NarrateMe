# API Keys
API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional tuning
IMAGE_QUALITY=medium            # low | medium | high
IMAGE_SIZE=1024x1024            # 1024x1024 | 1024x1536 | 1536x1024
# Comma-separated allowed frontend origins (set to your Vercel URL in prod)
CORS_ORIGINS=http://localhost:3000
# Regex for allowed origins, matched in addition to CORS_ORIGINS. Defaults to
# this project's Vercel URLs so every per-deploy/preview URL is accepted.
# CORS_ORIGIN_REGEX=https://narrateme-[a-z0-9-]+\.vercel\.app
